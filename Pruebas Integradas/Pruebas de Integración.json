{
  "info": {
    "name": "Pruebas de Integracion Automatizadas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Creacion de Publicacion",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El servidor responde con estado 201 Creado\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"El documento contiene el ID de usuario correcto\", function () {",
              "    var respuesta = pm.response.json();",
              "    pm.expect(respuesta.userId).to.eql(101);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json; charset=UTF-8"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Validacion de Integracion\",\n  \"body\": \"Este es un texto de prueba automatizada.\",\n  \"userId\": 101\n}"
        },
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/posts",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
            "typicode",
            "com"
          ],
          "path": [
            "posts"
          ]
        }
      }
    }
  ]
}